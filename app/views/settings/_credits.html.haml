%h2.mb-2 Crédits

.space-y-2
  %p.flex.items-baseline.gap-1 
    = t("settings.show.developed_by")
    %a.unstyled.text-primary.underline.transition{href: "https://github.com/theiereman", target: "_blank"} Thomas Eyermann
    %span= lucide_icon "square-arrow-out-up-right", class: "text-primary size-3.5"

  %p.flex.items-baseline.gap-1
    = t("settings.show.contribute")
    %a.unstyled.text-primary.underline{href: "https://github.com/theiereman/time-tracker", target: "_blank"}= t("settings.show.project")
    %span= lucide_icon "square-arrow-out-up-right", class: "text-primary size-3.5"
    
  %p.flex.items-baseline.gap-1
    = t("settings.show.icons_by")
    %a.unstyled.text-primary.underline{href: "https://lucide.dev", target: "_blank"} Lucide.dev
    %span= lucide_icon "square-arrow-out-up-right", class: "text-primary size-3.5"